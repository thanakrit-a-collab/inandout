datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

generator client {
  provider = "prisma-client-js"
}

// โมเดลสำหรับผู้ใช้งานแอปพลิเคชัน
model User {
  id           String        @id @default(uuid())
  lineUserId   String        @unique @map("line_user_id") // รหัส LINE User ID สำหรับใช้จับคู่/ผูกบัญชีบอท
  email        String?       @unique
  createdAt    DateTime      @default(now()) @map("created_at")
  transactions Transaction[]

  @@map("users")
}

// โมเดลสำหรับบันทึกประวัติรายรับ-รายจ่าย
model Transaction {
  id        String   @id @default(uuid())
  amount    Decimal  @db.Decimal(12, 2) // เก็บยอดเงินแบบทศนิยมเพื่อความแม่นยำสูง
  type      String   // ประเภท income หรือ expense (ตัวพิมพ์เล็ก)
  category  String   // หมวดหมู่ เช่น อาหาร, เงินเดือน, อื่นๆ
  note      String?  @map("description") // รายละเอียดเพิ่มเติม / ผู้จ่ายเงิน
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date // วันที่เกิดรายการ
  createdAt DateTime @default(now()) @map("created_at")

  @@map("transactions")
}
